{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(node *)",
      "Bash(npx serve *)",
      "Bash(npx @playwright/mcp@latest --version)",
      "Bash(npx @upstash/context7-mcp@latest --version)",
      "Bash(claude mcp *)",
      "Bash(claude update *)",
      "Bash(claude plugin *)",
      "Bash(curl -s http://localhost:3000/)",
      "Bash(echo \"PID=$!\")",
      "Bash(Start-Sleep -Seconds 2)",
      "Bash(Write-Output \"Server ready\")",
      "Bash(Remove-Item *)",
      "PowerShell(git *)",
      "PowerShell(git grep *)",
      "PowerShell(node *)",
      "PowerShell(claude mcp *)",
      "PowerShell(New-Item *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Remove-Item *)",
      "PowerShell($env:GITHUB_PERSONAL_ACCESS_TOKEN; $env:GITHUB_TOKEN)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_network_requests"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "caveman@caveman": true
  }
}